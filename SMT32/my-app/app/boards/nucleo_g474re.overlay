/*
 * SPDX-License-Identifier: Apache-2.0
 *
 * NUCLEO-G474RE overlay para o analisador de espectro em tempo real.
 *
 * Pinout:
 *   PA4  - DAC1_OUT1 / ADC2_IN17 (loopback analógico, já no board DTS)
 *   PB10 - USART3_TX  → ESP32 RX (GND comum obrigatório entre as placas)
 *   PA5  - LED LD2    (já definido como led0 no board DTS)
 *   PC13 - Botão B1   (já definido como sw0 no board DTS)
 *
 * DAC1_CH1, ADC2 e TIM6 são configurados via STM32Cube HAL em dac_hw.c/
 * adc_hw.c, não precisam de nó no devicetree.
 */

/* USART3 → ESP32, 115200 8N1, só TX (o ESP32 nunca responde) */
&usart3 {
	pinctrl-0 = <&usart3_tx_pb10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
	/* DMA1 CH4 (idx 3) req 0x1D = USART3_TX */
	dmas = <&dmamux1 3 0x1D (STM32_DMA_MEMORY_TO_PERIPH | STM32_DMA_MEM_INC)>;
	dma-names = "tx";
};

/* Habilitar DMA1 e DMAMUX1 para o driver Zephyr do USART3 */
&dma1 {
	status = "okay";
};

&dmamux1 {
	status = "okay";
};

/* DAC1 desabilitado: dac_hw.c inicializa tudo via HAL (PA4, TIM6, sem DMA). */
&dac1 {
	status = "disabled";
};
